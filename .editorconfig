root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true

[*.{kt,kts}]
indent_style = space
indent_size = 2
max_line_length = 120
# Composable functions use PascalCase by convention — suppress the ktlint rule
ktlint_function_naming_ignore_when_annotated_with = Composable
# CompositionLocals use PascalCase (Local*) by convention
ktlint_standard_property-naming = disabled
